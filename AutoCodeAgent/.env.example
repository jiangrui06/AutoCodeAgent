# 复制为 .env 后填写。系统环境变量的优先级高于本文件。

# ── OpenAI 兼容 LLM（必填） ──
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.siliconflow.cn/v1
LLM_MODEL=deepseek-ai/DeepSeek-V4-Pro

# ── LLM 参数 ──
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=8192
LLM_TIMEOUT=300
# 部分推理模型会把内容放入非标准 reasoning 字段；遇到空回复时开启
LLM_DISABLE_REASONING=false

# ── Agent 与执行环境 ──
AGENT_MAX_RETRY=5
SANDBOX_TIMEOUT=15

# ── Web 服务 ──
WEB_SERVER_NAME=127.0.0.1
WEB_SERVER_PORT=7870
WEB_INBROWSER=true

# ── 长期记忆 / Obsidian ──
MEMORY_ENABLED=true
# 留空时默认使用 ~/Documents/AutoCodeAgent-Memory
# MEMORY_DIR=C:\Users\your-name\Documents\AutoCodeAgent-Memory
MEMORY_RECALL_LIMIT=12
ERROR_MEMORY_RECALL_LIMIT=3

# ── LangSmith（可选） ──
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=autocode-agent

# 兼容旧版变量：如果继续使用 SILICONFLOW_API_KEY / BASE_URL / MODEL，
# 无需迁移；同时存在时，优先使用上面的 LLM_* 变量。
